{
  "_comment": "Reference document only. Claude Code does not support a separate hooks.json. Copy the 'hooks' section into your settings.json to use.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/remote-command-guard.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rate-limiter.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__supabase__execute_sql|mcp__supabase__apply_migration",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/db-guard.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__playwright__*|mcp__hyperbrowser__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/expensive-mcp-warning.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/output-secret-filter.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/code-quality-reminder.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/security-auto-trigger.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/commit-session.sh",
            "async": true,
            "timeout": 120
          }
        ]
      }
    ]
  }
}
